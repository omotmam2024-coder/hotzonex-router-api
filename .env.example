# Hotzonex Router API — copy to .env and fill in values

# Supabase (service role — server-side only, NEVER expose to browser)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# AES-256 encryption key for router passwords (32 random bytes as 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your64hexcharshere

# Allowed origins for CORS (comma-separated, or * for dev)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5175,https://yourdomain.vercel.app

PORT=3001
